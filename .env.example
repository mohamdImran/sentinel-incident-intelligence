# ─── SENTINEL Environment Configuration ──────────────────────────────────────
# Copy this file to .env and fill in your values.


# ─── Mode ─────────────────────────────────────────────────────────────────────
# true  → fully offline demo with scripted scenarios (default)
# false → connects to live Elasticsearch + Elastic Agent Builder
VITE_DEMO_MODE=true

# ─── Elasticsearch ────────────────────────────────────────────────────────────
# Elastic Cloud deployment URL 
VITE_ES_URL=https://your-deployment.es.us-central1.gcp.cloud.es.io:443
# Base64-encoded API key: btoa("id:api_key")
VITE_ES_API_KEY=your_base64_encoded_api_key_here

# ─── Kibana / Agent Builder ───────────────────────────────────────────────────
# Kibana endpoint for your Elastic Cloud deployment
VITE_KIBANA_URL=https://your-deployment.kb.us-central1.gcp.cloud.es.io
# API key with agent_builder read/write privileges
VITE_KIBANA_API_KEY=your_kibana_api_key_here


VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Demo playback (optional overrides) ──────────────────────────────────────
# VITE_DEMO_AUTO_PLAY=true
# VITE_DEMO_PLAYBACK_SPEED=1.0
# VITE_DEMO_LOOP=true
# VITE_DEMO_LOOP_DELAY_MS=6000
# VITE_DEMO_SCENARIO=0          # 0=DB Cascade | 1=CDN Outage | 2=Auth Attack
# VITE_DEMO_TYPING_SPEED_MS=16  # ms per character (lower = faster)
